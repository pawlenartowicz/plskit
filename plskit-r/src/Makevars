TARGET_DIR = ./rust/target
LIBDIR = $(TARGET_DIR)/release
STATLIB = $(LIBDIR)/libplskit_r.a
PKG_LIBS = -L$(LIBDIR) -lplskit_r

all: C_clean

$(SHLIB): $(STATLIB)

$(STATLIB):
	cd rust && cargo build --release --offline 2>/dev/null || cd rust && cargo build --release

C_clean:
	rm -Rf $(SHLIB) $(OBJECTS)

clean:
	rm -Rf $(SHLIB) $(OBJECTS) $(TARGET_DIR)
